OPENAI_API_KEY=pega_aqui_una_clave_nueva
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=45

# Railway: referencias al servicio MySQL. En XAMPP pueden omitirse.
ASISTIGO_DB_HOST=127.0.0.1
ASISTIGO_DB_PORT=3306
ASISTIGO_DB_NAME=asistigo
ASISTIGO_DB_USER=root
ASISTIGO_DB_PASS=

# Origenes separados por coma. Capacitor Android usa http://localhost.
ASISTIGO_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Credencial Firebase Admin codificada completamente en base64.
ASISTIGO_FIREBASE_JSON_BASE64=

# URL publica sin barra final, por ejemplo https://api.up.railway.app
ASISTIGO_PUBLIC_URL=
